{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "lib": ["ES2020"],
      "strict": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "allowImportingTsExtensions" : true,
      "skipLibCheck": true,
      "noEmit": true,
      "types": ["jest", "node"]
    },
    "include": ["*.test.ts", "*.ts"]
  }